<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Focus" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 text-stone-900 antialiased">
    <div class="min-h-screen flex flex-col items-center justify-center px-4">
      <div class="w-full max-w-xl">
        <header class="mb-10 text-center">
          <h1 class="text-3xl font-semibold tracking-tight text-stone-800">Focus</h1>
          <p class="text-sm text-stone-400 mt-1"><%= Date.current.strftime("%A, %-d %B %Y") %></p>
          <%= link_to "History", history_path, class: "text-sm text-stone-400 hover:text-emerald-600 transition-colors" %>
        </header>

        <% if notice.present? %>
          <div class="mb-6 rounded-lg bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-700">
            <%= notice %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </div>
  </body>
</html>

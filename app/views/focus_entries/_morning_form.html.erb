<div class="space-y-8">
  <div>
    <h2 class="text-xl font-medium text-stone-700">Good morning.</h2>
    <p class="mt-1 text-stone-500 text-sm">Let's set your intention for the day.</p>
  </div>

  <%= form_with model: @entry, url: focus_entry_path, method: :post, class: "space-y-6" do |f| %>
    <div class="space-y-2">
      <%= f.label :primary_focus, "What is your primary focus for today?",
            class: "block text-sm font-medium text-stone-700" %>
      <%= f.text_area :primary_focus,
            rows: 3,
            autofocus: true,
            placeholder: "Describe the one thing that would make today a success…",
            class: "mt-1 block w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-sm text-stone-900 placeholder-stone-400 shadow-sm focus:border-stone-500 focus:outline-none focus:ring-1 focus:ring-stone-500" %>
      <% if @entry.errors[:primary_focus].any? %>
        <p class="text-xs text-red-600"><%= @entry.errors[:primary_focus].first %></p>
      <% end %>
    </div>

    <div class="space-y-2">
      <%= f.label :anticipated_blockers, "What blockers do you envisage?",
            class: "block text-sm font-medium text-stone-700" %>
      <%= f.text_area :anticipated_blockers,
            rows: 3,
            placeholder: "Meetings, dependencies, unknowns… (optional)",
            class: "mt-1 block w-full rounded-lg border border-stone-300 bg-white px-3 py-2 text-sm text-stone-900 placeholder-stone-400 shadow-sm focus:border-stone-500 focus:outline-none focus:ring-1 focus:ring-stone-500" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Set today's focus",
            class: "w-full rounded-lg bg-stone-800 px-4 py-2.5 text-sm font-medium text-white hover:bg-stone-700 focus:outline-none focus:ring-2 focus:ring-stone-500 focus:ring-offset-2 cursor-pointer transition-colors" %>
    </div>
  <% end %>
</div>
